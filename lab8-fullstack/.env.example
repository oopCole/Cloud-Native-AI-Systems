# Postgres (defaults match docker-compose)
POSTGRES_DB=lab8
POSTGRES_USER=lab8
POSTGRES_PASSWORD=lab8-password
DATABASE_URL=postgresql://lab8:lab8-password@db:5432/lab8

# OpenRouter / OpenAI-compatible (required for "Run analysis"; no secrets in code)
# Leave blank only if you inject the key another way; empty OPENROUTER_API_KEY= in .env blocks the pipeline.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional OpenRouter attribution (see https://openrouter.ai/docs/api/reference/authentication)
# OPENROUTER_HTTP_REFERER=https://localhost
# OPENROUTER_APP_TITLE=lab8-fullstack
LLM_MODEL=google/gemma-3-4b-it:free

# RAG / embeddings (read by lab8-ai service)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_TOP_K=6
CHUNK_SIZE=800
CHUNK_OVERLAP=150
LLM_MAX_OUTPUT_TOKENS=8192

# Optional: set only if you want the browser to call the API directly (skip /lab8-api proxy)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
